{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "sourcecheckup_input_schema_v0_1.json",
  "title": "SourceCheckup Medical Input V0.1",
  "type": "object",
  "required": ["answer_id", "prompt", "answer"],
  "additionalProperties": true,
  "properties": {
    "answer_id": {
      "type": "string",
      "minLength": 1
    },
    "prompt": {
      "type": "string"
    },
    "answer": {
      "type": "string"
    },
    "declared_sources": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["source_id", "type", "value", "verification_status"],
        "additionalProperties": true,
        "properties": {
          "source_id": {
            "type": "string",
            "minLength": 1
          },
          "type": {
            "type": "string",
            "enum": ["doi", "pmid", "url", "guideline", "policy", "other"]
          },
          "value": {
            "type": "string",
            "minLength": 1
          },
          "title": {
            "type": "string"
          },
          "verification_status": {
            "type": "string",
            "enum": [
              "verified_external",
              "format_checked_only",
              "not_checked",
              "self_reported",
              "not_applicable"
            ]
          },
          "supports_claim_ids": {
            "type": "array",
            "items": {
              "type": "string"
            }
          }
        }
      }
    },
    "declared_claims": {
      "type": "array",
      "items": {
        "type": "object",
        "required": ["claim_id", "claim_type", "text"],
        "additionalProperties": true,
        "properties": {
          "claim_id": {
            "type": "string",
            "minLength": 1
          },
          "claim_type": {
            "type": "string",
            "enum": ["doi", "pmid", "url", "guideline", "policy", "evidence", "other"]
          },
          "text": {
            "type": "string",
            "minLength": 1
          },
          "source_ids": {
            "type": "array",
            "items": {
              "type": "string"
            }
          },
          "central_to_answer": {
            "type": "boolean"
          }
        }
      }
    }
  }
}
